# Ghost OS Configuration
#
# IMPORTANT: Ghost OS requires macOS 14+ and Swift 6.2+.
# It cannot be containerized on Linux. See README.md for details.

# MCP Server
GHOST_MCP_PORT=0  # 0 = auto (stdio transport)

# Vision Sidecar (Python)
VISION_SIDECAR_PORT=8765
VISION_MODEL=ShowUI-2B

# Recipe Directory
RECIPES_DIR=~/.ghost-os/recipes

# Logging
LOG_LEVEL=info
